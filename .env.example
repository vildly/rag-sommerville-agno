# Скопируйте в .env и при необходимости поправьте значения:
#   cp .env.example .env
# Затем подгрузите перед запуском, например:
#   export $(grep -v '^#' .env | xargs)

# Провайдер эмбеддингов: ollama (локально) или openai
EMBEDDER=ollama

# Строка подключения к pgvector (совпадает с docker-compose.yml)
DB_URL=postgresql+psycopg://ai:ai@localhost:5532/ai

# Путь к PDF. По умолчанию берётся учебник Sommerville из папки курса.
# Раскомментируйте, чтобы указать свой:
# PDF_PATH=/Users/oxluaa/rag/sommerville/sommerville-10.pdf

# Чанкинг (в символах; ~4000 символов соответствует ~1000 токенам)
CHUNK_SIZE=4000
CHUNK_OVERLAP=400

# Только для EMBEDDER=ollama
OLLAMA_HOST=http://localhost:11434
# CHAT_MODEL=llama3.1

# Только для EMBEDDER=openai
# OPENAI_API_KEY=sk-...
# CHAT_MODEL=gpt-4o-mini
